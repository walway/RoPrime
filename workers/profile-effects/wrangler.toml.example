name = "roprime-profile-effects"
main = "src/index.js"
compatibility_date = "2024-06-01"

# 1. Create KV: Cloudflare dashboard → Workers & Pages → KV → Create namespace
# 2. Paste namespace id below (and preview_id for wrangler dev)
[[kv_namespaces]]
binding = "PROFILE_EFFECTS_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_PREVIEW_KV_NAMESPACE_ID"

# Optional: require header X-RoPrime-Secret on POST /purchase and /equip
# Set via: wrangler secret put REGISTER_SECRET
# [vars]
# ALLOWED_ORIGIN = "https://www.roblox.com"
